# FloatChat environment variables
# Copy this file to .env.local and fill in your values

# Supabase (required for auth, leads, and newsletter forms)
# Get these from: https://app.supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: used for Supabase admin operations (server-side only — never expose in browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (used for OAuth redirect URLs)
VITE_APP_URL=http://localhost:5173

# Analytics (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
